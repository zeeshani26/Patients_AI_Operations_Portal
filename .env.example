# Copy to ".env" in the repo root (never commit ".env"):
#   cp .env.example .env
#
# Gemini (optional but recommended for AI Copilot chat)
GEMINI_API_KEY=
GOOGLE_API_KEY=
USE_GEMINI=true
USE_GEMINI_AUGMENT=true
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-flash,gemini-1.5-pro
GEMINI_MAX_WORDS=140
